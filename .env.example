# =============================================================================
# PreviewBot — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
# Required vars must be set before the server will start.
# Optional vars have defaults shown; omit them to accept the default.
# =============================================================================


# =============================================================================
# REQUIRED
# =============================================================================

# =============================================================================
# AUTH — choose one mode
# =============================================================================

# PAT mode: a personal access token with repo scope.
# Required if not using GitHub App mode.
GITHUB_TOKEN=

# GitHub App mode: set all three to enable auto-repo-discovery.
# GITHUB_APP_ID and GITHUB_APP_PRIVATE_KEY replace GITHUB_TOKEN.
# Private key: paste the PEM content with literal \n between lines, or use
# actual newlines inside double quotes in this file.
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----

# SQLite database path for tracking app installations and repos.
# Only used in GitHub App mode.
# DB_PATH=/var/previewbot/installations.db

# Secret used to verify the HMAC-SHA256 signature on incoming GitHub webhooks.
# Set this to the same value configured in your GitHub webhook settings.
GITHUB_WEBHOOK_SECRET=

# Base domain for preview URLs, e.g. preview.example.com
# Must match your DNS wildcard record and nginx configuration.
# Each PR will be served at https://pr-<number>.<PREVIEW_DOMAIN>
PREVIEW_DOMAIN=


# =============================================================================
# OPTIONAL — Core Server
# =============================================================================

# Port the PreviewBot HTTP server listens on.
PORT=3500

# Filesystem path where built preview deployments are stored.
DEPLOY_DIR=/var/previewbot/deploys

# Filesystem path where per-PR secrets (e.g. injected env files) are stored.
SECRETS_DIR=/var/previewbot/secrets

# Directory where per-PR nginx config files are written.
# Nginx must be configured to include files from this directory.
NGINX_CONF_DIR=/etc/nginx/conf.d

# Docker network that preview containers are attached to.
DOCKER_NETWORK=pr-previews

# Memory limit applied to each preview container (Docker --memory format).
CONTAINER_MEMORY=512m

# CPU quota applied to each preview container (Docker --cpus format).
CONTAINER_CPUS=1

# Maximum time in seconds allowed for a preview build before it is aborted.
BUILD_TIMEOUT=600

# Maximum time in seconds to wait for a container health check to pass.
HEALTH_CHECK_TIMEOUT=60

# Filesystem path where Lighthouse and axe audit reports are stored.
REPORT_DIR=/var/previewbot/reports

# Path to the SSL certificate for preview subdomains (wildcard cert).
# SSL_CERT_PATH=/etc/letsencrypt/live/preview.example.com/fullchain.pem

# Path to the SSL private key for preview subdomains.
# SSL_KEY_PATH=/etc/letsencrypt/live/preview.example.com/privkey.pem

# Absolute path to the Chrome/Chromium binary used by Lighthouse.
# If unset, Puppeteer's bundled Chromium is used automatically.
# Example: /usr/bin/chromium-browser
# CHROME_PATH=

# Set to true to disable the Chrome sandbox inside the audit container.
# Required when running audits inside Docker or in rootless environments.
DISABLE_CHROME_SANDBOX=true


# =============================================================================
# OPTIONAL — AI & Audits
# =============================================================================

# Anthropic API key used for AI-powered visual diff analysis.
# Visual diff is disabled when this key is absent.
ANTHROPIC_API_KEY=

# Production URL to compare against during visual diff.
# When set, screenshots of the preview and production are diffed by Claude.
PRODUCTION_URL=

# Maximum time in seconds for a single Lighthouse/axe audit run.
AUDIT_TIMEOUT=120

# Comma-separated list of URL paths to include in each audit.
# Paths are appended to the preview base URL.
AUDIT_PATHS=/

# Set to true to post audit results as GitHub Check Runs on the PR.
CHECK_RUNS_ENABLED=true

# Claude model used for visual diff comparison.
VISUAL_DIFF_MODEL=claude-sonnet-4-5-20250929


# =============================================================================
# OPTIONAL — Quality Thresholds
# =============================================================================
# Scores are 0-100. A threshold of 0 disables that gate entirely.
# The PR check fails if any enabled threshold is not met.

# Minimum Lighthouse performance score required to pass.
THRESHOLD_PERFORMANCE=0

# Minimum Lighthouse accessibility score required to pass.
THRESHOLD_ACCESSIBILITY=0

# Minimum Lighthouse best-practices score required to pass.
THRESHOLD_BEST_PRACTICES=0

# Minimum Lighthouse SEO score required to pass.
THRESHOLD_SEO=0

# Maximum number of axe critical-severity violations allowed.
THRESHOLD_AXE_CRITICAL=0

# Maximum number of axe serious-severity violations allowed.
THRESHOLD_AXE_SERIOUS=5

# Maximum number of critical visual diff issues allowed.
THRESHOLD_VISUAL_CRITICAL=0
